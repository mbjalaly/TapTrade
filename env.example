# ============================================
# BACKEND API CONFIGURATION (RAILWAY)
# ============================================
# Your Railway backend deployment URL
API_BASE_URL=https://taptrade-backend-production.up.railway.app/
IMAGE_BASE_URL=https://taptrade-backend-production.up.railway.app

# Payment API URL (separate Railway service)
PAYMENT_API_URL=https://taptrade-payment-production.up.railway.app/api/payment/

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these from Firebase Console > Project Settings > Your apps
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ============================================
# GOOGLE MAPS API
# ============================================
# Get from Google Cloud Console > APIs & Services > Credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================
# APP CONFIGURATION
# ============================================
APP_NAME=TapTrade
APP_VERSION=1.0.0
ENVIRONMENT=production

# Port for Railway web deployment
PORT=8080

